<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autoexcel.MainController">
    <children>
        <Label text="Robô de Automação (Multi-Base)" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <Label text="1. Selecione a planilha geral (.xlsx):" textFill="#34495e">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="filePathField" editable="false" prefHeight="35.0" prefWidth="420.0" promptText="Caminho do arquivo .xlsx..." style="-fx-background-radius: 5;" />
                <Button fx:id="selectFileButton" mnemonicParsing="false" onAction="#handleSelectFile" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Procurar Arquivo" />
            </children>
        </HBox>
        
        <Label text="2. Painel de Bases (Separadas pela Coluna B):" textFill="#34495e">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        
        <ScrollPane fitToWidth="true" prefHeight="250.0" style="-fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="cardsContainer" hgap="15.0" vgap="15.0" style="-fx-padding: 10;" />
            </content>
        </ScrollPane>

        <Label text="3. Logs da Base em Execução:" textFill="#34495e">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        
        <TextArea fx:id="logArea" editable="false" prefHeight="200.0" prefWidth="550.0" style="-fx-control-inner-background: #282a36; -fx-text-fill: #50fa7b; -fx-font-family: 'Consolas', monospace; -fx-font-size: 13px;" wrapText="true" />
        
    </children>
</VBox>
